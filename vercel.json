{
  "installCommand": "npm install --include=optional",
  "functions": {
    "api/[...all].ts": {
      "includeFiles": "api/dist/** prisma/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...all]"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "trailingSlash": false
}
