# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Kashier Integration
KASHIER_MERCHANT_ID=
KASHIER_API_KEY=
KASHIER_SECRET_KEY=
KASHIER_TEST_MODE=true

# Supabase / PostgreSQL
SUPABASE_URL=
SUPABASE_ANON_KEY=
# For Vercel + Supabase, use the Transaction mode URL (Port 6543)
# Append ?pgbouncer=true&connection_limit=1&sslmode=require to prevent connection errors
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
