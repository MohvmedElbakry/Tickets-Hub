# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Kashier Integration
KASHIER_MERCHANT_ID=
KASHIER_API_KEY=
KASHIER_SECRET_KEY=
KASHIER_TEST_MODE=true

# Supabase / PostgreSQL
# For Vercel + Supabase, use the Transaction mode URL (Port 6543)
# Set connection_limit based on your database tier. 1 is too low for most operations.
# 10 is a good starting point for pooled connections.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=10&sslmode=require"
# Direct URL used for running migrations (Port 5432)
DIRECT_URL="postgresql://user:password@host:5432/postgres?sslmode=require"

# Email Configuration (Supports SMTP or Resend API)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@yourdomain.com
SMTP_PASS=your_smtp_pass_here
SMTP_FROM="TicketsHub Notifications <noreply@yourdomain.com>"
RESEND_API_KEY=re_yourresendapikey
FRONTEND_URL=http://localhost:3000
