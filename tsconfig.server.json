{
  "compilerOptions": {
    "outDir": "api/dist",
    "rootDir": ".",
    "module": "ESNext",
    "target": "ES2020",
    "jsx": "react-jsx",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": ["api/**/*.ts", "api/**/*.tsx", "src/types.ts", "src/lib/utils.ts"],
  "exclude": ["api/[...all].ts", "api/dist/**/*"]
}