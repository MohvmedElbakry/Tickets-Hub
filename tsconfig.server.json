{
  "compilerOptions": {
    "outDir": "api/dist",
    "rootDir": "api",
    "module": "NodeNext",
    "target": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx"
  },
  "include": ["api/**/*.ts", "api/**/*.tsx"],
  "exclude": ["api/[...all].ts", "api/dist/**/*"]
}